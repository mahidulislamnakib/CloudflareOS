{
  "name": "server-side-tracking-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-26",
  "queues": {
    "producers": [
      {
        "binding": "TRACKING_QUEUE",
        "queue": "tracking-events"
      }
    ],
    "consumers": [
      {
        "queue": "tracking-events"
      }
    ]
  }
}
